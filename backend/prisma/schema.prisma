// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Organization / Factory / Site
// ─────────────────────────────────────────────

model Organization {
  organizationID   Int     @id @default(autoincrement()) @map("OrganizationID")
  organizationName String? @map("OrganizationName")
  organizationCode String? @unique @map("OrganizationCode")
  status           String? @map("Status")

  users     User[]
  zones     Zone[]
  devices   Device[]
  recipes   Recipe[]
  batches   Batch[]
  alerts    Alert[]
  factories Factory[]

  @@map("Organizations")
}

model Factory {
  factoryID      Int     @id @default(autoincrement()) @map("FactoryID")
  organizationID Int?    @map("OrganizationID")
  factoryName    String? @map("FactoryName")
  factoryCode    String? @unique @map("FactoryCode")
  status         String? @map("Status")

  organization Organization? @relation(fields: [organizationID], references: [organizationID])
  users        User[]
  zones        Zone[]
  devices      Device[]
  recipes      Recipe[]
  batches      Batch[]
  alerts       Alert[]
  sites        Site[]

  @@map("Factories")
}

model Site {
  siteID    Int     @id @default(autoincrement()) @map("SiteID")
  factoryID Int?    @map("FactoryID")
  siteName  String? @map("SiteName")
  siteCode  String? @unique @map("SiteCode")
  status    String? @map("Status")

  factory Factory? @relation(fields: [factoryID], references: [factoryID])
  users   User[]
  zones   Zone[]
  devices Device[]
  recipes Recipe[]
  batches Batch[]
  alerts  Alert[]

  @@map("Sites")
}

// ─────────────────────────────────────────────
// User & Access
// ─────────────────────────────────────────────

model User {
  userID      Int       @id @default(autoincrement())
  password    String?
  email       String?
  phoneNumber String?   @map("PhoneNumber")
  dateOfBirth DateTime? @db.Date
  gender      String?
  firstName   String?
  lastName    String?
  status      String?
  createdAt   DateTime? @db.Timestamptz
  role        String?   @map("Role")
  organizationID Int?   @map("OrganizationID")
  factoryID      Int?   @map("FactoryID")
  siteID         Int?   @map("SiteID")

  organization Organization? @relation(fields: [organizationID], references: [organizationID])
  factory      Factory?      @relation(fields: [factoryID], references: [factoryID])
  site         Site?         @relation(fields: [siteID], references: [siteID])

  zones               Zone[]
  recipes             Recipe[]
  recipeModifications RecipeModification[]
  batchOperations     BatchOperation[]
  alertResolutions    AlertResolution[]
  systemConfigUpdates SystemConfigUpdate[]

  @@map("User")
}

// ─────────────────────────────────────────────
// Zone & Device
// ─────────────────────────────────────────────

model Zone {
  zoneID          Int     @id @default(autoincrement()) @map("ZoneID")
  zoneName        String? @map("ZoneName")
  zoneDescription String? @map("ZoneDescription")
  userID          Int?    @map("userID")
  organizationID  Int?    @map("OrganizationID")
  factoryID       Int?    @map("FactoryID")
  siteID          Int?    @map("SiteID")

  user    User?    @relation(fields: [userID], references: [userID])
  organization Organization? @relation(fields: [organizationID], references: [organizationID])
  factory      Factory?      @relation(fields: [factoryID], references: [factoryID])
  site         Site?         @relation(fields: [siteID], references: [siteID])
  devices Device[]

  @@map("Zones")
}

model Device {
  deviceID        Int     @id @default(autoincrement()) @map("DeviceID")
  deviceName      String? @map("DeviceName")
  deviceStatus    String? @map("DeviceStatus")
  mqttTopicSensor String? @map("MQTTTopicSensor")
  mqttTopicCmd    String? @map("MQTTTopicCmd")
  deviceType      String? @map("DeviceType")
  metaData        Json?   @map("MetaData")
  zoneID          Int?    @map("ZoneID")
  organizationID  Int?    @map("OrganizationID")
  factoryID       Int?    @map("FactoryID")
  siteID          Int?    @map("SiteID")

  zone       Zone?           @relation(fields: [zoneID], references: [zoneID])
  organization Organization? @relation(fields: [organizationID], references: [organizationID])
  factory      Factory?      @relation(fields: [factoryID], references: [factoryID])
  site         Site?         @relation(fields: [siteID], references: [siteID])
  batches    Batch[]
  sensorLogs SensorDataLog[]
  alerts     Alert[]
  sensorChannels   SensorChannel[]
  actuatorChannels ActuatorChannel[]

  @@map("Devices")
}

model SensorChannel {
  sensorChannelID Int     @id @default(autoincrement()) @map("SensorChannelID")
  deviceID        Int?    @map("DeviceID")
  sensorName      String? @map("SensorName")
  sensorType      String? @map("SensorType")
  feedKey         String  @unique @map("FeedKey")
  status          String? @map("Status")
  unit            String? @map("Unit")
  sortOrder       Int?    @map("SortOrder")
  metaData        Json?   @map("MetaData")

  device Device? @relation(fields: [deviceID], references: [deviceID])

  @@map("SensorChannels")
}

model ActuatorChannel {
  actuatorChannelID Int     @id @default(autoincrement()) @map("ActuatorChannelID")
  deviceID          Int?    @map("DeviceID")
  actuatorName      String? @map("ActuatorName")
  actuatorType      String? @map("ActuatorType")
  feedKey           String  @unique @map("FeedKey")
  status            String? @map("Status")
  controlMode       String? @map("ControlMode")
  onValue           String? @map("OnValue")
  offValue          String? @map("OffValue")
  sortOrder         Int?    @map("SortOrder")
  metaData          Json?   @map("MetaData")

  device Device? @relation(fields: [deviceID], references: [deviceID])

  @@map("ActuatorChannels")
}

// ─────────────────────────────────────────────
// Recipe & Steps
// ─────────────────────────────────────────────

model Recipe {
  recipeID        Int     @id @default(autoincrement()) @map("RecipeID")
  recipeName      String? @map("RecipeName")
  recipeFruits    String? @map("RecipeFruits")
  timeDurationEst Int?    @map("TimeDurationEst")
  userID          Int?    @map("userID")
  organizationID  Int?    @map("OrganizationID")
  factoryID       Int?    @map("FactoryID")
  siteID          Int?    @map("SiteID")
  isActive        Boolean @default(true) @map("IsActive")

  user                User?                @relation(fields: [userID], references: [userID])
  organization        Organization?        @relation(fields: [organizationID], references: [organizationID])
  factory             Factory?             @relation(fields: [factoryID], references: [factoryID])
  site                Site?                @relation(fields: [siteID], references: [siteID])
  steps               RecipeStep[]
  stages              RecipeStage[]
  batches             Batch[]
  recipeModifications RecipeModification[]

  @@map("Recipes")
}

model RecipeStage {
  stageID              Int    @id @default(autoincrement()) @map("StageID")
  recipeID             Int?   @map("RecipeID")
  stageOrder           Int    @map("StageOrder")
  durationMinutes      Int    @map("DurationMinutes")
  temperatureSetpoint  Float  @map("TemperatureSetpoint")
  humiditySetpoint     Float  @map("HumiditySetpoint")

  recipe Recipe? @relation(fields: [recipeID], references: [recipeID])

  @@unique([recipeID, stageOrder])
  @@map("RecipeStage")
}

model RecipeStep {
  stepID          Int     @id @default(autoincrement()) @map("StepID")
  recipeID        Int?    @map("RecipeID")
  stepNo          Int?    @map("StepNo")
  temperatureGoal Float?  @map("TemperatureGoal")
  humidityGoal    Float?  @map("HumidityGoal")
  durationMinutes Int?    @map("DurationMinutes")
  fanStatus       String? @map("FanStatus")
  stepStatus      String? @map("StepStatus")

  recipe Recipe? @relation(fields: [recipeID], references: [recipeID])

  @@map("RecipeSteps")
}

model RecipeModification {
  rmID       Int       @id @default(autoincrement()) @map("RM_ID")
  userID     Int?      @map("userID")
  recipeID   Int?      @map("RecipeID")
  modifiedAt DateTime? @db.Timestamptz @map("ModifiedAt")

  user   User?   @relation(fields: [userID], references: [userID])
  recipe Recipe? @relation(fields: [recipeID], references: [recipeID])

  @@map("RecipeModification")
}

// ─────────────────────────────────────────────
// Batch & Operations
// ─────────────────────────────────────────────

model Batch {
  batchesID     Int     @id @default(autoincrement()) @map("BatchesID")
  batchStatus   String? @map("BatchStatus")
  batchResult   String? @map("BatchResult")
  operationMode String? @map("OperationMode")
  currentStep   Int?    @map("CurrentStep")
  currentStage  Int?    @map("CurrentStage")
  startedAt     DateTime? @db.Timestamptz @map("StartedAt")
  stageStartedAt DateTime? @db.Timestamptz @map("StageStartedAt")
  recipeID      Int?    @map("RecipeID")
  deviceID      Int?    @map("DeviceID")
  organizationID Int?   @map("OrganizationID")
  factoryID      Int?   @map("FactoryID")
  siteID         Int?   @map("SiteID")

  recipe          Recipe?          @relation(fields: [recipeID], references: [recipeID])
  device          Device?          @relation(fields: [deviceID], references: [deviceID])
  organization    Organization?    @relation(fields: [organizationID], references: [organizationID])
  factory         Factory?         @relation(fields: [factoryID], references: [factoryID])
  site            Site?            @relation(fields: [siteID], references: [siteID])
  batchOperations BatchOperation[]
  alerts          Alert[]

  @@map("Batches")
}

model BatchOperation {
  boID      Int       @id @default(autoincrement()) @map("BO_ID")
  userID    Int?      @map("userID")
  batchesID Int?      @map("BatchesID")
  startedAt DateTime? @db.Timestamptz @map("StartedAt")
  endedAt   DateTime? @db.Timestamptz @map("EndedAt")

  user  User?  @relation(fields: [userID], references: [userID])
  batch Batch? @relation(fields: [batchesID], references: [batchesID])

  @@map("BatchOperation")
}

// ─────────────────────────────────────────────
// Sensor
// ─────────────────────────────────────────────

model SensorDataLog {
  logID        Int       @id @default(autoincrement()) @map("LogID")
  measurements Json?     @map("Measurements")
  logTimestamp DateTime? @db.Timestamptz @map("LogTimestamp")
  deviceID     Int?      @map("DeviceID")

  device Device? @relation(fields: [deviceID], references: [deviceID])

  @@map("SensorDataLog")
}

// ─────────────────────────────────────────────
// System Config
// ─────────────────────────────────────────────

model SystemConfig {
  configKey   String  @id @map("ConfigKey")
  configValue String? @map("ConfigValue")

  systemConfigUpdates SystemConfigUpdate[]

  @@map("SystemConfig")
}

model SystemConfigUpdate {
  scuID     Int       @id @default(autoincrement()) @map("SCU_ID")
  userID    Int?      @map("userID")
  configKey String?   @map("ConfigKey")
  updatedAt DateTime? @db.Timestamptz @map("UpdatedAt")

  user         User?         @relation(fields: [userID], references: [userID])
  systemConfig SystemConfig? @relation(fields: [configKey], references: [configKey])

  @@map("SystemConfigUpdate")
}

// ─────────────────────────────────────────────
// Alerts
// ─────────────────────────────────────────────

model Alert {
  alertID      Int       @id @default(autoincrement()) @map("AlertID")
  alertType    String?   @map("AlertType")
  alertMessage String?   @map("AlertMessage")
  alertTime    DateTime? @db.Timestamptz @map("AlertTime")
  alertStatus  String?   @map("AlertStatus")
  deviceID     Int?      @map("DeviceID")
  batchesID    Int?      @map("BatchesID")
  organizationID Int?    @map("OrganizationID")
  factoryID      Int?    @map("FactoryID")
  siteID         Int?    @map("SiteID")

  device           Device?           @relation(fields: [deviceID], references: [deviceID])
  batch            Batch?            @relation(fields: [batchesID], references: [batchesID])
  organization     Organization?     @relation(fields: [organizationID], references: [organizationID])
  factory          Factory?          @relation(fields: [factoryID], references: [factoryID])
  site             Site?             @relation(fields: [siteID], references: [siteID])
  alertResolutions AlertResolution[]

  @@map("Alerts")
}

model AlertResolution {
  arID          Int       @id @default(autoincrement()) @map("AR_ID")
  userID        Int?      @map("userID")
  alertID       Int?      @map("AlertID")
  resolveTime   DateTime? @db.Timestamptz @map("ResolveTime")
  resolveStatus String?   @map("ResolveStatus")
  resolveNote   String?   @map("ResolveNote")

  user  User?  @relation(fields: [userID], references: [userID])
  alert Alert? @relation(fields: [alertID], references: [alertID])

  @@map("AlertResolution")
}
